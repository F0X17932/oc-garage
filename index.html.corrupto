    66|  <!-- FONTS -->
    67|  <link rel="preconnect" href="https://fonts.googleapis.com" />
    68|  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    69|  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;900&family=Work+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
    70|
    71|  <style>
    72|    /* ══════════════════════════════════════
    73|       VARIABLES & RESET
    74|    ══════════════════════════════════════ */
    75|    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    76|
    77|    :root {
    78|      --c-black:   #0C0C0C;
    79|      --c-dark:    #141414;
    80|      --c-dark-2:  #1E1E1E;
    81|      --c-dark-3:  #2A2A2A;
    82|      --c-mid:     #7A7A7A;
    83|      --c-light:   #EFEFEF;
    84|      --c-red:     #C01820;
    85|      --c-red-dk:  #9A1219;
    86|      --c-red-glow:rgba(192,24,32,0.18);
    87|      --f-disp:    'Big Shoulders Display', sans-serif;
    88|      --f-body:    'Work Sans', sans-serif;
    89|      --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
    90|    }
    91|
    92|    html {
    93|      scroll-behavior: smooth;
    94|      cursor: none;
    95|    }
    96|    @media (hover: none) { html { cursor: auto; } }
    97|
    98|    body {
    99|      background: var(--c-black);
   100|      color: var(--c-light);
   101|      font-family: var(--f-body);
   102|      font-size: 16px;
   103|      line-height: 1.6;
   104|      -webkit-font-smoothing: antialiased;
   105|      overflow-x: hidden;
   106|    }
   107|    a, button { cursor: none; }
   108|    @media (hover: none) { a, button { cursor: auto; } }
   109|
   110|    img { display: block; max-width: 100%; }
   111|    a { color: inherit; text-decoration: none; }
   112|
   113|    .container {
   114|      width: 100%;
   115|      max-width: 1200px;
   116|      margin: 0 auto;
   117|      padding: 0 32px;
   118|    }
   119|
   120|    /* ══════════════════════════════════════
   121|       CUSTOM CURSOR
   122|    ══════════════════════════════════════ */
   123|    #cursor-dot,
   124|    #cursor-ring {
   125|      position: fixed;
   126|      border-radius: 50%;
   127|      pointer-events: none;
   128|      z-index: 9999;
   129|      transform: translate(-50%, -50%);
   130|      transition: opacity 0.3s;
   131|    }
   132|    #cursor-dot {
   133|      width: 6px; height: 6px;
   134|      background: var(--c-red);
   135|      top: 0; left: 0;
   136|    }
   137|    #cursor-ring {
   138|      width: 36px; height: 36px;
   139|      border: 1.5px solid rgba(192,24,32,0.5);
   140|      top: 0; left: 0;
   141|      transition: width 0.25s var(--ease-out-expo),
   142|                  height 0.25s var(--ease-out-expo),
   143|                  border-color 0.25s;
   144|    }
   145|    #cursor-ring.hover {
   146|      width: 56px; height: 56px;
   147|      border-color: var(--c-red);
   148|    }
   149|    @media (hover: none) {
   150|      #cursor-dot, #cursor-ring { display: none; }
   151|    }
   152|
   153|    /* ══════════════════════════════════════
   154|       GRAIN TEXTURE
   155|    ══════════════════════════════════════ */
   156|    .grain {
   157|      position: fixed;
   158|      inset: -200%;
   159|      width: 400%; height: 400%;
   160|      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
   161|      background-repeat: repeat;
   162|      background-size: 256px 256px;
   163|      opacity: 0.028;
   164|      pointer-events: none;
   165|      z-index: 1000;
   166|      animation: grain-shift 0.8s steps(1) infinite;
   167|    }
   168|    @keyframes grain-shift {
   169|      0%   { transform: translate(0,0); }
   170|      10%  { transform: translate(-3%,-3%); }
   171|      20%  { transform: translate(3%,3%); }
   172|      30%  { transform: translate(-3%,1%); }
   173|      40%  { transform: translate(1%,-3%); }
   174|      50%  { transform: translate(-1%,3%); }
   175|      60%  { transform: translate(3%,-1%); }
   176|      70%  { transform: translate(-3%,3%); }
   177|      80%  { transform: translate(3%,-3%); }
   178|      90%  { transform: translate(-1%,1%); }
   179|      100% { transform: translate(3%,1%); }
   180|    }
   181|
   182|    /* ══════════════════════════════════════
   183|       BUTTONS
   184|    ══════════════════════════════════════ */
   185|    .btn {
   186|      display: inline-flex;
   187|      align-items: center;
   188|      gap: 10px;
   189|      padding: 15px 30px;
   190|      font-family: var(--f-disp);
   191|      font-size: 0.9rem;
   192|      font-weight: 700;
   193|      letter-spacing: 0.08em;
   194|      text-transform: uppercase;
   195|      border: none;
   196|      border-radius: 2px;
   197|      position: relative;
   198|      overflow: hidden;
   199|      transition: transform 0.2s var(--ease-out-expo);
   200|    }
   201|    .btn::after {
   202|      content: '';
   203|      position: absolute;
   204|      inset: 0;
   205|      background: rgba(255,255,255,0.07);
   206|      opacity: 0;
   207|      transition: opacity 0.2s;
   208|    }
   209|    .btn:hover { transform: translateY(-3px); }
   210|    .btn:hover::after { opacity: 1; }
   211|
   212|    .btn-red  { background: var(--c-red); color: #fff; }
   213|    .btn-red:hover { box-shadow: 0 12px 32px rgba(192,24,32,0.4); }
   214|
   215|    .btn-ghost {
   216|      background: transparent;
   217|      color: var(--c-light);
   218|      border: 1px solid rgba(255,255,255,0.2);
   219|    }
   220|    .btn-ghost:hover { border-color: rgba(255,255,255,0.6); }
   221|
   222|    .btn-wa   { background: #25D366; color: #fff; }
   223|    .btn-wa:hover { box-shadow: 0 12px 32px rgba(37,211,102,0.35); }
   224|
   225|    /* ══════════════════════════════════════
   226|       NAVBAR
   227|    ══════════════════════════════════════ */
   228|    .navbar {
   229|      position: fixed;
   230|      top: 0; left: 0; right: 0;
   231|      z-index: 500;
   232|      padding: 24px 0;
   233|    }
   234|    .navbar::before {
   235|      content: '';
   236|      position: absolute;
   237|      inset: 0;
   238|      background: rgba(12,12,12,0);
   239|      backdrop-filter: blur(0px);
   240|      transition: background 0.4s, backdrop-filter 0.4s;
   241|      pointer-events: none;
   242|    }
   243|    .navbar.scrolled::before {
   244|      background: rgba(12,12,12,0.88);
   245|      backdrop-filter: blur(16px);
   246|    }
   247|    .navbar.scrolled { padding: 16px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
   248|    .navbar .container {
   249|      display: flex;
   250|      align-items: center;
   251|      justify-content: space-between;
   252|      position: relative;
   253|      z-index: 1;
   254|    }
   255|    .navbar .container {
   256|      display: grid;
   257|      grid-template-columns: auto 1fr auto;
   258|      align-items: center;
   259|    }
   260|    .nav-left { display: flex; align-items: center; justify-content: flex-start; }
   261|    .nav-center { display: none; }
   262|    .nav-right-desktop { display: flex; align-items: center; justify-content: flex-end; gap: 20px; }
   263|
   264|    /* Logo */
   265|    .logo {
   266|      display: flex;
   267|      align-items: center;
   268|      gap: 12px;
   269|      opacity: 0; /* animated in */
   270|    }
   271|    .logo-mark {
   272|      width: 110px; height: 110px;
   273|      display: flex; align-items: center; justify-content: center;
   274|      flex-shrink: 0;
   275|    }
   276|    .logo-mark img {
   277|      width: 100%; height: 100%;
   278|      object-fit: contain;
   279|      display: block;
   280|    }
   281|    .logo-info { display: flex; flex-direction: column; line-height: 1.1; }
   282|    .logo-info strong {
   283|      font-family: var(--f-disp);
   284|      font-weight: 900;
   285|      font-size: 1.15rem;
   286|      letter-spacing: 0.1em;
   287|      text-transform: uppercase;
   288|    }
   289|    .logo-info small {
   290|      font-size: 0.7rem;
   291|      letter-spacing: 0.22em;
   292|      text-transform: uppercase;
   293|      color: var(--c-mid);
   294|    }
   295|
   296|    .nav-right {
   297|      display: flex;
   298|      align-items: center;
   299|      justify-content: flex-end;
   300|      gap: 12px;
   301|    }
   302|    .nav-ig {
   303|      display: flex; align-items: center; gap: 6px;
   304|      font-size: 0.78rem; letter-spacing: 0.06em;
   305|      color: var(--c-mid);
   306|      transition: color 0.2s;
   307|    }
   308|    .nav-ig:hover { color: var(--c-light); }
   309|
   310|    /* ══════════════════════════════════════
   311|       HERO
   312|    ══════════════════════════════════════ */
   313|    .hero {
   314|      position: relative;
   315|      min-height: 100svh;
   316|      display: flex;
   317|      align-items: flex-end;
   318|      overflow: hidden;
   319|    }
   320|
   321|    /* Grid lines background */
   322|    .hero-grid {
   323|      position: absolute;
   324|      inset: 0;
   325|      background-image:
   326|        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
   327|        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
   328|      background-size: 80px 80px;
   329|      z-index: 0;
   330|      mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
   331|    }
   332|
   333|    /* Red glow */
   334|    .hero-glow {
   335|      position: absolute;
   336|      top: 15%; right: -5%;
   337|      width: 700px; height: 700px;
   338|      background: radial-gradient(circle, rgba(192,24,32,0.15) 0%, transparent 65%);
   339|      z-index: 0;
   340|      pointer-events: none;
   341|    }
   342|
   343|    /* OC watermark */
   344|    .hero-wm {
   345|      position: absolute;
   346|      top: 42%;
   347|      left: 72%;
   348|      transform: translate(-50%, -50%);
   349|      width: clamp(480px, 72vw, 900px);
   350|      height: clamp(480px, 72vw, 900px);
   351|      opacity: 0.04;
   352|      pointer-events: none;
   353|      user-select: none;
   354|      z-index: 0;
   355|    }
   356|    .hero-wm img {
   357|      width: 100%;
   358|      height: 100%;
   359|      object-fit: contain;
   360|      display: block;
   361|    }
   362|
   363|    /* Diagonal accent */
   364|    .hero-line {
   365|      position: absolute;
   366|      top: 0; right: 22%;
   367|      width: 1px;
   368|      height: 100%;
   369|      background: linear-gradient(to bottom, transparent, rgba(192,24,32,0.3) 40%, transparent);
   370|      z-index: 0;
   371|    }
   372|
   373|    .hero .container {
   374|      position: relative;
   375|      z-index: 1;
   376|      padding-bottom: 80px;
   377|      padding-top: 120px;
   378|      display: grid;
   379|      grid-template-columns: 1fr 1fr;
   380|      gap: 0 64px;
   381|      align-items: end;
   382|    }
   383|
   384|    .hero-left {}
   385|
   386|    .hero-tag {
   387|      display: inline-flex;
   388|      align-items: center;
   389|      gap: 10px;
   390|      font-size: 0.7rem;
   391|      font-weight: 600;
   392|      letter-spacing: 0.28em;
   393|      text-transform: uppercase;
   394|      color: var(--c-red);
   395|      margin-bottom: 28px;
   396|      overflow: hidden;
   397|    }
   398|    .hero-tag::before {
   399|      content: '';
   400|      display: block;
   401|      width: 28px; height: 1.5px;
   402|      background: var(--c-red);
   403|      transform: scaleX(0);
   404|      transform-origin: left;
   405|    }
   406|
   407|    /* Text reveal wrapper */
   408|    .reveal-line {
   409|      overflow: hidden;
   410|      display: block;
   411|    }
   412|
   413|    .hero h1 {
   414|      font-family: var(--f-disp);
   415|      font-weight: 900;
   416|      font-size: clamp(60px, 9vw, 120px);
   417|      line-height: 0.88;
   418|      letter-spacing: -0.01em;
   419|      text-transform: uppercase;
   420|      color: var(--c-light);
   421|      margin-bottom: 36px;
   422|    }
   423|    .hero h1 em {
   424|      font-style: normal;
   425|      color: var(--c-red);
   426|    }
   427|
   428|    .hero-sub {
   429|      font-size: 1rem;
   430|      color: var(--c-mid);
   431|      line-height: 1.75;
   432|      margin-bottom: 40px;
   433|      max-width: 380px;
   434|    }
   435|
   436|    .hero-ctas {
   437|      display: flex;
   438|      flex-wrap: wrap;
   439|      gap: 12px;
   440|    }
   441|
   442|    /* Right col: stats */
   443|    .hero-right {
   444|      display: flex;
   445|      flex-direction: column;
   446|      justify-content: flex-end;
   447|      gap: 1px;
   448|      padding-left: 40px;
   449|      border-left: 1px solid rgba(255,255,255,0.07);
   450|    }
   451|
   452|    .stat-block {
   453|      padding: 28px 0;
   454|      border-bottom: 1px solid rgba(255,255,255,0.06);
   455|    }
   456|    .stat-block:first-child { border-top: 1px solid rgba(255,255,255,0.06); }
   457|
   458|    .stat-num {
   459|      font-family: var(--f-disp);
   460|      font-weight: 900;
   461|      font-size: clamp(3rem, 5vw, 4.5rem);
   462|      line-height: 1;
   463|      color: var(--c-light);
   464|      display: flex;
   465|      align-items: baseline;
   466|      gap: 2px;
   467|    }
   468|    .stat-num sup {
   469|      font-size: 0.45em;
   470|      color: var(--c-red);
   471|      font-weight: 900;
   472|    }
   473|    .stat-label {
   474|      font-size: 0.72rem;
   475|      letter-spacing: 0.16em;
   476|      text-transform: uppercase;
   477|      color: var(--c-mid);
   478|      margin-top: 6px;
   479|    }
   480|
   481|    /* ══════════════════════════════════════
   482|       TICKER / PILARES
   483|    ══════════════════════════════════════ */
   484|    .ticker-wrap {
   485|      background: var(--c-red);
   486|      padding: 16px 0;
   487|      overflow: hidden;
   488|      position: relative;
   489|    }
   490|    .ticker-track {
   491|      display: flex;
   492|      white-space: nowrap;
   493|      will-change: transform;
   494|    }
   495|    .ticker-item {
   496|      display: inline-flex;
   497|      align-items: center;
   498|      gap: 20px;
   499|      padding: 0 32px;
   500|      font-family: var(--f-disp);
   501|      font-weight: 700;
   502|      font-size: 0.82rem;
   503|      letter-spacing: 0.22em;
   504|      text-transform: uppercase;
   505|      color: #fff;
   506|      flex-shrink: 0;
   507|    }
   508|    .ticker-sep {
   509|      width: 4px; height: 4px;
   510|      background: rgba(255,255,255,0.5);
   511|      border-radius: 50%;
   512|      flex-shrink: 0;
   513|    }
   514|
   515|    /* ══════════════════════════════════════
   516|       SERVICIOS
   517|    ══════════════════════════════════════ */
   518|    .servicios {
   519|      padding: 120px 0;
   520|    }
   521|
   522|    .section-head {
   523|      display: grid;
   524|      grid-template-columns: 1fr 1fr;
   525|      gap: 40px 80px;
   526|      align-items: end;
   527|      margin-bottom: 72px;
   528|    }
   529|
   530|    .s-tag {
   531|      display: inline-flex;
   532|      align-items: center;
   533|      gap: 10px;
   534|      font-size: 0.68rem;
   535|      font-weight: 600;
   536|      letter-spacing: 0.28em;
   537|      text-transform: uppercase;
   538|      color: var(--c-red);
   539|      margin-bottom: 14px;
   540|    }
   541|    .s-tag::before {
   542|      content: '';
   543|      display: block;
   544|      width: 24px; height: 1.5px;
   545|      background: var(--c-red);
   546|    }
   547|
   548|    .s-title {
   549|      font-family: var(--f-disp);
   550|      font-weight: 900;
   551|      font-size: clamp(40px, 5.5vw, 68px);
   552|      line-height: 0.9;
   553|      text-transform: uppercase;
   554|    }
   555|    .s-title em { font-style: normal; color: var(--c-red); }
   556|
   557|    .s-desc {
   558|      font-size: 0.95rem;
   559|      color: var(--c-mid);
   560|      line-height: 1.75;
   561|      align-self: end;
   562|    }
   563|
   564|    /* Cards */
   565|    .cards-grid {
   566|      display: grid;
   567|      grid-template-columns: repeat(3, 1fr);
   568|      gap: 2px;
   569|    }
   570|
   571|    .card {
   572|      background: var(--c-dark-2);
   573|      padding: 48px 40px;
   574|      position: relative;
   575|      overflow: hidden;
   576|      transition: background 0.3s;
   577|    }
   578|    .card::before {
   579|      content: '';
   580|      position: absolute;
   581|      bottom: 0; left: 0;
   582|      width: 100%; height: 2px;
   583|      background: var(--c-red);
   584|      transform: scaleX(0);
   585|      transform-origin: left;
   586|      transition: transform 0.4s var(--ease-out-expo);
   587|    }
   588|    .card::after {
   589|      content: '';
   590|      position: absolute;
   591|      top: 0; right: 0;
   592|      width: 140px; height: 140px;
   593|      background: radial-gradient(circle, var(--c-red-glow), transparent 70%);
   594|      opacity: 0;
   595|      transition: opacity 0.4s;
   596|      pointer-events: none;
   597|    }
   598|    .card:hover { background: var(--c-dark-3); }
   599|    .card:hover::before { transform: scaleX(1); }
   600|    .card:hover::after { opacity: 1; }
   601|
   602|    .card-num {
   603|      font-family: var(--f-disp);
   604|      font-weight: 900;
   605|      font-size: 5rem;
   606|      line-height: 1;
   607|      color: rgba(192,24,32,0.1);
   608|      position: absolute;
   609|      top: 24px; right: 28px;
   610|      transition: color 0.3s;
   611|    }
   612|    .card:hover .card-num { color: rgba(192,24,32,0.2); }
   613|
   614|    .card-icon {
   615|      width: 48px; height: 48px;
   616|      border: 1px solid rgba(192,24,32,0.3);
   617|      border-radius: 2px;
   618|      display: flex; align-items: center; justify-content: center;
   619|      color: var(--c-red);
   620|      margin-bottom: 28px;
   621|      transition: background 0.3s, border-color 0.3s;
   622|    }
   623|    .card:hover .card-icon {
   624|      background: rgba(192,24,32,0.1);
   625|      border-color: var(--c-red);
   626|    }
   627|
   628|    .card-title {
   629|      font-family: var(--f-disp);
   630|      font-weight: 900;
   631|      font-size: 1.65rem;
   632|      text-transform: uppercase;
   633|      letter-spacing: 0.02em;
   634|      margin-bottom: 14px;
   635|    }
   636|    .card-desc {
   637|      font-size: 0.88rem;
   638|      color: var(--c-mid);
   639|      line-height: 1.75;
   640|      margin-bottom: 28px;
   641|    }
   642|    .card-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
   643|    .card-list li {
   644|      display: flex; align-items: center; gap: 10px;
   645|      font-size: 0.8rem;
   646|      color: var(--c-mid);
   647|    }
   648|    .card-list li::before {
   649|      content: '';
   650|      display: block;
   651|      width: 4px; height: 4px;
   652|      background: var(--c-red);
   653|      border-radius: 50%;
   654|      flex-shrink: 0;
   655|    }
   656|
   657|    /* ══════════════════════════════════════
   658|       PROCESO (minimal horizontal)
   659|    ══════════════════════════════════════ */
   660|    .proceso {
   661|      padding: 80px 0 120px;
   662|      border-top: 1px solid rgba(255,255,255,0.05);
   663|    }
   664|    .proceso-steps {
   665|      display: grid;
   666|      grid-template-columns: repeat(4, 1fr);
   667|      gap: 2px;
   668|      margin-top: 60px;
   669|    }
   670|    .step {
   671|      padding: 36px 32px;
   672|      background: var(--c-dark);
   673|      position: relative;
   674|    }
   675|    .step::after {
   676|      content: attr(data-n);
   677|      position: absolute;
   678|      top: 20px; right: 20px;
   679|      font-family: var(--f-disp);
   680|      font-weight: 900;
   681|      font-size: 3.5rem;
   682|      color: rgba(255,255,255,0.04);
   683|      line-height: 1;
   684|    }
   685|    .step-label {
   686|      font-size: 0.65rem;
   687|      letter-spacing: 0.2em;
   688|      text-transform: uppercase;
   689|      color: var(--c-red);
   690|      margin-bottom: 14px;
   691|    }
   692|    .step-title {
   693|      font-family: var(--f-disp);
   694|      font-weight: 900;
   695|      font-size: 1.2rem;
   696|      text-transform: uppercase;
   697|      letter-spacing: 0.03em;
   698|      margin-bottom: 10px;
   699|    }
   700|    .step-desc {
   701|      font-size: 0.83rem;
   702|      color: var(--c-mid);
   703|      line-height: 1.6;
   704|    }
   705|
   706|    /* ══════════════════════════════════════
   707|       CTA FINAL
   708|    ══════════════════════════════════════ */
   709|    .cta-section {
   710|      padding: 140px 0;
   711|      text-align: center;
   712|      position: relative;
   713|      overflow: hidden;
   714|    }
   715|    .cta-section::before {
   716|      content: '';
   717|      position: absolute;
   718|      inset: 0;
   719|      background: radial-gradient(ellipse 80% 100% at 50% 50%, rgba(192,24,32,0.08) 0%, transparent 70%);
   720|      pointer-events: none;
   721|    }
   722|    .cta-section .container { position: relative; z-index: 1; }
   723|
   724|    .cta-big {
   725|      font-family: var(--f-disp);
   726|      font-weight: 900;
   727|      font-size: clamp(52px, 9vw, 130px);
   728|      line-height: 0.88;
   729|      text-transform: uppercase;
   730|      color: var(--c-light);
   731|      margin-bottom: 16px;
   732|    }
   733|    .cta-big em { font-style: normal; color: var(--c-red); }
   734|
   735|    .cta-sub {
   736|      font-size: 1rem;
   737|      color: var(--c-mid);
   738|      margin-bottom: 48px;
   739|      line-height: 1.7;
   740|    }
   741|    .cta-btns {
   742|      display: flex;
   743|      flex-wrap: wrap;
   744|      justify-content: center;
   745|      gap: 14px;
   746|    }
   747|
   748|    /* ══════════════════════════════════════
   749|       FOOTER
   750|    ══════════════════════════════════════ */
   751|    footer {
   752|      background: var(--c-dark);
   753|      border-top: 1px solid rgba(255,255,255,0.05);
   754|      padding: 60px 0 32px;
   755|    }
   756|    .footer-top {
   757|      display: grid;
   758|      grid-template-columns: 1.4fr 1fr 1fr;
   759|      gap: 60px;
   760|      padding-bottom: 48px;
   761|      border-bottom: 1px solid rgba(255,255,255,0.05);
   762|      margin-bottom: 32px;
   763|    }
   764|    .footer-brand p {
   765|      font-size: 0.82rem;
   766|      color: var(--c-mid);
   767|      line-height: 1.7;
   768|      margin-top: 16px;
   769|      max-width: 280px;
   770|    }
   771|    .footer-col h5 {
   772|      font-size: 0.65rem;
   773|      font-weight: 600;
   774|      letter-spacing: 0.22em;
   775|      text-transform: uppercase;
   776|      color: var(--c-red);
   777|      margin-bottom: 20px;
   778|    }
   779|    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
   780|    .footer-col li a, .footer-col li span {
   781|      font-size: 0.85rem;
   782|      color: var(--c-mid);
   783|      transition: color 0.2s;
   784|    }
   785|    .footer-col li a:hover { color: var(--c-light); }
   786|
   787|    .footer-bottom {
   788|      display: flex;
   789|      flex-wrap: wrap;
   790|      align-items: center;
   791|      justify-content: space-between;
   792|      gap: 12px;
   793|    }
   794|    .footer-bottom p {
   795|      font-size: 0.75rem;
   796|      color: rgba(122,122,122,0.6);
   797|    }
   798|    .footer-bottom a { color: var(--c-red); }
   799|
   800|    /* ══════════════════════════════════════
   801|       FLOATING WA
   802|    ══════════════════════════════════════ */
   803|    .wa-fab {
   804|      position: fixed;
   805|      bottom: 28px; right: 28px;
   806|      z-index: 400;
   807|      width: 56px; height: 56px;
   808|      background: #25D366;
   809|      border-radius: 50%;
   810|      display: flex; align-items: center; justify-content: center;
   811|      box-shadow: 0 4px 24px rgba(37,211,102,0.4);
   812|      opacity: 0; /* animated in */
   813|      transform: scale(0.8);
   814|    }
   815|    .wa-fab svg { width: 28px; height: 28px; fill: #fff; }
   816|
   817|    /* ══════════════════════════════════════
   818|       PROGRESS LINE
   819|    ══════════════════════════════════════ */
   820|    #progress {
   821|      position: fixed;
   822|      top: 0; left: 0;
   823|      height: 2px;
   824|      background: var(--c-red);
   825|      z-index: 600;
   826|      transform-origin: left;
   827|      transform: scaleX(0);
   828|    }
   829|
   830|    /* ══════════════════════════════════════
   831|       RESPONSIVE
   832|    ══════════════════════════════════════ */
   833|    /* OFF-CANVAS MENU */
   834|    .nav-toggle {
   835|      display: flex;
   836|      flex-direction: column;
   837|      gap: 5px;
   838|      background: none;
   839|      border: none;
   840|      padding: 8px;
   841|      cursor: pointer;
   842|      z-index: 1001;
   843|    }
   844|    .nav-toggle span {
   845|      display: block;
   846|      width: 24px;
   847|      height: 2px;
   848|      background: var(--c-light);
   849|      transition: 0.3s;
   850|    }
   851|    .nav-toggle.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
   852|    .nav-toggle.active span:nth-child(2) { opacity: 0; }
   853|    .nav-toggle.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }
   854|
   855|    /* Overlay */
   856|    .offcanvas-overlay {
   857|      position: fixed;
   858|      inset: 0;
   859|      background: rgba(12,12,12,0.6);
   860|      backdrop-filter: blur(4px);
   861|      z-index: 998;
   862|      opacity: 0;
   863|      visibility: hidden;
   864|      transition: opacity 0.4s ease, visibility 0.4s ease;
   865|    }
   866|    .offcanvas-overlay.active { opacity: 1; visibility: visible; }
   867|
   868|    /* Off-canvas panel */
   869|    .offcanvas-menu {
   870|      position: fixed;
   871|      top: 0; right: 0; bottom: 0;
   872|      width: 33vw;
   873|      min-width: 320px;
   874|      max-width: 480px;
   875|      background: var(--c-dark);
   876|      border-left: 1px solid rgba(255,255,255,0.06);
   877|      z-index: 999;
   878|      display: flex;
   879|      flex-direction: column;
   880|      padding: 100px 40px 40px;
   881|      gap: 6px;
   882|      transform: translateX(100%);
   883|      transition: transform 0.5s var(--ease-out-expo);
   884|    }
   885|    .offcanvas-menu.active { transform: translateX(0); }
   886|
   887|    .offcanvas-close {
   888|      position: absolute;
   889|      top: 28px;
   890|      right: 32px;
   891|      width: 44px;
   892|      height: 44px;
   893|      display: flex;
   894|      align-items: center;
   895|      justify-content: center;
   896|      background: var(--c-red);
   897|      border: none;
   898|      border-radius: 2px;
   899|      cursor: pointer;
   900|      z-index: 1000;
   901|      transition: background 0.2s, transform 0.2s;
   902|    }
   903|    .offcanvas-close:hover { background: var(--c-red-dk); transform: scale(1.05); }
   904|    .offcanvas-close svg {
   905|      width: 18px;
   906|      height: 18px;
   907|      stroke: #fff;
   908|      stroke-width: 2.5;
   909|      stroke-linecap: round;
   910|    }
   911|
   912|    .offcanvas-menu a {
   913|      font-family: var(--f-disp);
   914|      font-size: 1.6rem;
   915|      font-weight: 700;
   916|      letter-spacing: 0.06em;
   917|      text-transform: uppercase;
   918|      color: var(--c-light);
   919|      padding: 14px 0;
   920|      border-bottom: 1px solid rgba(255,255,255,0.06);
   921|      transition: color 0.2s, padding-left 0.2s;
   922|    }
   923|    .offcanvas-menu a:hover { color: var(--c-red); padding-left: 8px; }
   924|    .offcanvas-menu .btn-red {
   925|      font-size: 1.1rem;
   926|      padding: 18px 40px;
   927|      margin-top: 24px;
   928|      text-align: center;
   929|      justify-content: center;
   930|    }
   931|    .offcanvas-footer {
   932|      margin-top: auto;
   933|      padding-top: 32px;
   934|      border-top: 1px solid rgba(255,255,255,0.06);
   935|      font-size: 0.75rem;
   936|      color: var(--c-mid);
   937|      letter-spacing: 0.1em;
   938|    }
   939|
   940|    @media (max-width: 768px) {
   941|      .nav-right-desktop { display: none !important; }
   942|      .navbar .container { grid-template-columns: auto 1fr auto; }
   943|      .logo-mark { width: 58px; height: 58px; }
   944|      .logo-info strong { font-size: 1.1rem; letter-spacing: 0.08em; }
   945|      .logo-info small { font-size: 0.58rem; letter-spacing: 0.16em; }
   946|      .offcanvas-menu { width: 100%; max-width: 100%; padding: 90px 28px 28px; }
   947|      .offcanvas-menu a { font-size: 1.35rem; padding: 12px 0; }
   948|    }
   949|
   950|    @media (max-width: 900px) {
   951|      .hero .container {
   952|        grid-template-columns: 1fr;
   953|      }
   954|      .hero-right {
   955|        padding-left: 0;
   956|        border-left: none;
   957|        border-top: 1px solid rgba(255,255,255,0.07);
   958|        padding-top: 40px;
   959|        flex-direction: row;
   960|        flex-wrap: wrap;
   961|        gap: 0;
   962|      }
   963|      .stat-block {
   964|        flex: 1;
   965|        min-width: 140px;
   966|        padding: 20px 24px;
   967|        border-bottom: none;
   968|        border-right: 1px solid rgba(255,255,255,0.06);
   969|      }
   970|      .stat-block:last-child { border-right: none; }
   971|      .section-head { grid-template-columns: 1fr; }
   972|      .cards-grid { grid-template-columns: 1fr; }
   973|      .proceso-steps { grid-template-columns: 1fr 1fr; }
   974|      .footer-top { grid-template-columns: 1fr; gap: 32px; }
   975|      .proceso-step .step-num { font-size: 64px; }
   976|    }
   977|
   978|    @media (max-width: 768px) {
   979|      .hero { min-height: auto; padding: 140px 0 60px; }
   980|      .hero .container { gap: 40px; }
   981|      .hero h1 { font-size: clamp(42px, 13vw, 72px); line-height: 0.92; }
   982|      .hero-sub { font-size: 1rem; }
   983|      .hero-ctas { flex-direction: column; gap: 12px; }
   984|      .hero-ctas .btn { width: 100%; justify-content: center; }
   985|      .section-title { font-size: clamp(36px, 10vw, 64px); }
   986|      .cards-grid { gap: 20px; }
   987|      .card { padding: 32px 24px; }
   988|      .proceso-steps { grid-template-columns: 1fr; gap: 32px; }
   989|      .proceso-step { padding: 32px 24px; }
   990|      .cta-big { font-size: clamp(36px, 11vw, 64px); }
   991|      .cta-final .btn { width: 100%; justify-content: center; }
   992|      .footer-top { gap: 40px; }
   993|      .footer-brand { max-width: 100%; }
   994|      .footer-brand .logo { justify-content: center; }
   995|      .footer-brand p { text-align: center; }
   996|      .footer-col { text-align: center; }
   997|      .footer-col ul { align-items: center; }
   998|      .footer-col a { justify-content: center; }
   999|      .wa-fab { width: 52px; height: 52px; bottom: 20px; right: 20px; }
  1000|      .wa-fab svg { width: 22px; height: 22px; }
  1001|    }
  1002|
  1003|    @media (max-width: 600px) {
  1004|      .container { padding: 0 20px; }
  1005|      .hero h1 { font-size: clamp(38px, 12vw, 64px); }
  1006|      .nav-right .btn { display: none; }
  1007|      .proceso-steps { grid-template-columns: 1fr; }
  1008|      .cta-big { font-size: clamp(32px, 11vw, 56px); }
  1009|      .section-title { font-size: clamp(32px, 10vw, 56px); }
  1010|      .stat-block { min-width: 120px; padding: 16px 12px; }
  1011|      .stat-num { font-size: 2rem; }
  1012|      .card { padding: 28px 20px; }
  1013|      .card h3 { font-size: 1.4rem; }
  1014|      .ticker { font-size: 0.75rem; padding: 14px 0; }
  1015|      .logo-mark { width: 64px; height: 64px; }
  1016|      .logo-info strong { font-size: 1.2rem; }
  1017|      .logo-info small { font-size: 0.62rem; }
  1018|    }
  1019|
  1020|    @media (max-width: 400px) {
  1021|      .hero h1 { font-size: clamp(34px, 11vw, 52px); }
  1022|      .section-title { font-size: clamp(28px, 9vw, 48px); }
  1023|      .stat-num { font-size: 1.6rem; }
  1024|      .stat-label { font-size: 0.65rem; }
  1025|      .card { padding: 24px 16px; }
  1026|      .btn { padding: 14px 24px; font-size: 0.8rem; }
  1027|    }
  1028|
    /* ════════════════════════════════════
       CONTACTO
    ════════════════════════════════════ */
    .contacto {
      padding: 100px 0 80px;
      border-top: 1px solid rgba(255,255,255,0.05);
    }
    .contacto-grid {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 48px;
      margin-top: 56px;
      align-items: start;
    }
    .contacto-map {
      width: 100%;
      height: 420px;
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.06);
    }
    .contacto-map iframe {
      width: 100%;
      height: 100%;
      border: 0;
      filter: grayscale(0.6) contrast(1.1);
    }
    .contacto-info {
      margin-bottom: 32px;
    }
    .contacto-info-item {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 20px;
      color: var(--c-mid);
      font-size: 0.9rem;
      line-height: 1.5;
    }
    .contacto-info-item svg {
      flex-shrink: 0;
      margin-top: 2px;
      color: var(--c-red);
    }
    .contacto-info-item strong {
      color: var(--c-light);
      display: block;
      font-weight: 600;
      margin-bottom: 2px;
      font-size: 0.82rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .contacto-info-item a {
      color: var(--c-mid);
      text-decoration: none;
      transition: color 0.2s;
    }
    .contacto-info-item a:hover { color: var(--c-red); }

    .contacto-form {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .contacto-form label {
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--c-mid);
      margin-bottom: -10px;
    }
    .contacto-form input,
    .contacto-form textarea {
      background: var(--c-dark);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 6px;
      padding: 14px 16px;
      color: var(--c-light);
      font-family: var(--f-body);
      font-size: 0.9rem;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      resize: vertical;
    }
    .contacto-form input:focus,
    .contacto-form textarea:focus {
      border-color: var(--c-red);
      box-shadow: 0 0 0 3px rgba(192,24,32,0.12);
    }
    .contacto-form input::placeholder,
    .contacto-form textarea::placeholder {
      color: rgba(122,122,122,0.5);
    }
    .contacto-form textarea { min-height: 120px; }
    .contacto-form .btn {
      align-self: flex-start;
      margin-top: 8px;
    }

    @media (max-width: 768px) {
      .contacto-grid {
        grid-template-columns: 1fr;
        gap: 40px;
      }
      .contacto-map { height: 320px; }
      .contacto { padding: 60px 0 50px; }
    }
  </style>
  1029|</head>
  1030|
  1031|<body>
  1032|
  1033|  <!-- Grain -->
  1034|  <div class="grain" aria-hidden="true"></div>
  1035|
  1036|  <!-- Custom cursor -->
  1037|  <div id="cursor-dot" aria-hidden="true"></div>
  1038|  <div id="cursor-ring" aria-hidden="true"></div>
  1039|
  1040|  <!-- Progress bar -->
  1041|  <div id="progress" aria-hidden="true"></div>
  1042|
  1043|  <!-- ══════════════════════════════════════
  1044|       NAVBAR
  1045|  ══════════════════════════════════════ -->
  1046|  <header>
