  1186|    <section class="servicios" id="servicios" aria-labelledby="s-title">
  1187|      <div class="container">
  1188|        <div class="section-head">
  1189|          <div>
  1190|            <p class="s-tag">Lo que hacemos</p>
  1191|            <h2 class="s-title" id="s-title">
  1192|              <span class="reveal-line"><span class="rl-inner">Nuestros</span></span>
  1193|              <span class="reveal-line"><span class="rl-inner"><em>Servicios</em></span></span>
  1194|            </h2>
  1195|          </div>
  1196|          <p class="s-desc">
  1197|            Chapa y pintura de alta calidad. Sin atajos, sin medias tintas. Cada trabajo sale del taller como tiene que salir — impecable.
  1198|          </p>
  1199|        </div>
  1200|
  1201|        <div class="cards-grid">
  1202|          <!-- Chapa -->
  1203|          <article class="card">
  1204|            <div class="card-num" aria-hidden="true">01</div>
  1205|            <div class="card-icon" aria-hidden="true">
  1206|              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
  1207|                <path d="M14.5 10.5L19 6M5 19l6.5-6.5M6 18l8.5-8.5m0 0L17 7l-2.5 2.5"/>
  1208|              </svg>
  1209|            </div>
  1210|            <h3 class="card-title">Chapa</h3>
  1211|            <p class="card-desc">Reparación profesional de carrocería. Abolladuras, deformaciones y daños estructurales resueltos con técnica de primer nivel.</p>
  1212|            <ul class="card-list" aria-label="Trabajos de chapa">
  1213|              <li>Reparación de abolladuras (PDR)</li>
  1214|              <li>Enderezado de carrocería</li>
  1215|              <li>Soldadura y reemplazo de paneles</li>
  1216|              <li>Preparación de superficie</li>
  1217|            </ul>
  1218|          </article>
  1219|
  1220|          <!-- Pintura -->
