  1382|  <!-- ══════════════════════════════════════
  1383|       GSAP
  1384|  ══════════════════════════════════════ -->
  1385|  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  1386|  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  1387|
  1388|  <script>
  1389|  (function() {
  1390|    gsap.registerPlugin(ScrollTrigger);
  1391|
  1392|    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  1393|
  1394|    /* ── Custom Cursor ─────────────────────── */
  1395|    const dot  = document.getElementById('cursor-dot');
  1396|    const ring = document.getElementById('cursor-ring');
  1397|
  1398|    if (window.matchMedia('(hover: hover)').matches && dot && ring) {
  1399|      let mx = 0, my = 0;
  1400|
  1401|      window.addEventListener('mousemove', e => {
  1402|        mx = e.clientX; my = e.clientY;
  1403|        gsap.to(dot,  { x: mx, y: my, duration: 0.05, ease: 'none' });
  1404|        gsap.to(ring, { x: mx, y: my, duration: 0.18, ease: 'power2.out' });
  1405|      });
  1406|
  1407|      document.querySelectorAll('a, button, .card, .step').forEach(el => {
  1408|        el.addEventListener('mouseenter', () => ring.classList.add('hover'));
  1409|        el.addEventListener('mouseleave', () => ring.classList.remove('hover'));
  1410|      });
  1411|    }
  1412|
  1413|    /* ── Progress Bar ──────────────────────── */
  1414|    const prog = document.getElementById('progress');
  1415|    window.addEventListener('scroll', () => {
  1416|      const pct = window.scrollY / (document.body.scrollHeight - window.innerHeight);
  1417|      gsap.set(prog, { scaleX: pct });
  1418|    }, { passive: true });
  1419|
  1420|    /* ── Navbar scroll ─────────────────────── */
  1421|    const navbar = document.getElementById('navbar');
  1422|    ScrollTrigger.create({
  1423|      start: 60,
  1424|      onEnter:     () => navbar.classList.add('scrolled'),
  1425|      onLeaveBack: () => navbar.classList.remove('scrolled'),
  1426|    });
  1427|
  1428|    /* ── Hero tag line reveal ──────────────── */
  1429|    const heroTag = document.getElementById('hero-tag-el');
  1430|    if (!prefersReduced) {
  1431|      gsap.from(heroTag.querySelector('::before') || heroTag, { /* tag line */
  1432|        opacity: 0, x: -20, duration: 0.8, delay: 0.2, ease: 'power3.out'
  1433|      });
  1434|      // Eyebrow
  1435|      gsap.fromTo(heroTag,
  1436|        { opacity: 0, x: -16 },
  1437|        { opacity: 1, x: 0, duration: 0.7, delay: 0.25, ease: 'power3.out' }
  1438|      );
  1439|
  1440|      /* h1 line reveal */
  1441|      gsap.fromTo('.hero h1 .rl-inner',
  1442|        { yPercent: 110, opacity: 0 },
  1443|        { yPercent: 0, opacity: 1, duration: 1, delay: 0.45, stagger: 0.1, ease: 'power4.out' }
  1444|      );
  1445|
  1446|      /* Sub + CTA */
  1447|      gsap.fromTo('#hero-sub',
  1448|        { opacity: 0, y: 20 },
  1449|        { opacity: 1, y: 0, duration: 0.8, delay: 0.85, ease: 'power3.out' }
  1450|      );
  1451|      gsap.fromTo('#hero-ctas .btn',
  1452|        { opacity: 0, y: 16 },
  1453|        { opacity: 1, y: 0, duration: 0.7, delay: 1.0, stagger: 0.1, ease: 'power3.out' }
  1454|      );
  1455|
  1456|      /* Stats */
  1457|      gsap.fromTo('#hero-stats .stat-block',
  1458|        { opacity: 0, y: 24 },
  1459|        { opacity: 1, y: 0, duration: 0.7, delay: 0.9, stagger: 0.12, ease: 'power3.out' }
  1460|      );
  1461|
  1462|      /* Navbar logo */
  1463|      gsap.to('.logo', { opacity: 1, duration: 0.6, delay: 0.1, ease: 'power2.out' });
  1464|      gsap.to('.nav-right', { opacity: 1, duration: 0.6, delay: 0.2, ease: 'power2.out' });
  1465|
  1466|      /* WA fab */
  1467|      gsap.to('#wa-fab', { opacity: 1, scale: 1, duration: 0.6, delay: 1.4, ease: 'back.out(2)' });
  1468|    } else {
  1469|      /* reduced motion: just show everything */
  1470|      gsap.set(['.logo', '.nav-right', '#wa-fab', '#hero-sub', '#hero-ctas .btn',
  1471|                 '#hero-stats .stat-block', heroTag, '.hero h1 .rl-inner'], { opacity: 1, clearProps: 'transform' });
  1472|    }
  1473|
  1474|    /* ── Stat counter ──────────────────────── */
  1475|    document.querySelectorAll('.counter').forEach(el => {
  1476|      const target = parseInt(el.dataset.target, 10);
  1477|      ScrollTrigger.create({
  1478|        trigger: el,
  1479|        start: 'top 85%',
  1480|        once: true,
  1481|        onEnter: () => {
  1482|          gsap.fromTo(el, { innerText: 0 }, {
  1483|            innerText: target,
  1484|            duration: 1.8,
  1485|            ease: 'power2.out',
  1486|            snap: { innerText: 1 },
  1487|            onUpdate() { el.textContent = Math.ceil(parseFloat(el.textContent)); }
  1488|          });
  1489|        }
  1490|      });
  1491|    });
  1492|
  1493|    /* ── Ticker (GSAP) ─────────────────────── */
  1494|    const track = document.getElementById('ticker-track');
  1495|    if (track) {
  1496|      const totalW = track.scrollWidth / 2; // half because content is doubled
  1497|      gsap.to(track, {
  1498|        x: -totalW,
  1499|        duration: 28,
  1500|        repeat: -1,
  1501|        ease: 'none',
  1502|        modifiers: {
  1503|          x: gsap.utils.unitize(v => parseFloat(v) % totalW)
  1504|        }
  1505|      });
  1506|    }
  1507|
  1508|    /* ── Section reveal lines (servicios / proceso) ── */
  1509|    if (!prefersReduced) {
  1510|      gsap.utils.toArray('.s-title .rl-inner, .cta-big .rl-inner').forEach(el => {
  1511|        gsap.fromTo(el,
  1512|          { yPercent: 110, opacity: 0 },
  1513|          {
  1514|            yPercent: 0, opacity: 1,
  1515|            duration: 0.9, ease: 'power4.out',
  1516|            scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' }
  1517|          }
  1518|        );
  1519|      });
  1520|
  1521|      /* Cards stagger */
  1522|      gsap.from('.card',
  1523|        {
  1524|          y: 48,
  1525|          duration: 0.75, stagger: 0.13, ease: 'power3.out',
  1526|          scrollTrigger: { trigger: '.cards-grid', start: 'top 80%' }
  1527|        }
  1528|      );
  1529|
  1530|      /* Steps stagger */
  1531|      gsap.from('.step',
  1532|        {
  1533|          y: 36,
  1534|          duration: 0.65, stagger: 0.1, ease: 'power3.out',
  1535|          scrollTrigger: { trigger: '.proceso-steps', start: 'top 82%' }
  1536|        }
  1537|      );
  1538|
  1539|      /* Footer fade */
  1540|      gsap.from('footer',
  1541|        {
  1542|          y: 20,
  1543|          duration: 0.8, ease: 'power2.out',
  1544|          scrollTrigger: { trigger: 'footer', start: 'top 90%' }
  1545|        }
  1546|      );
  1547|    }
  1548|
  1549|    /* ── Hero glow parallax ────────────────── */
  1550|    if (!prefersReduced) {
  1551|      gsap.to('.hero-glow', {
  1552|        y: 120,
  1553|        ease: 'none',
  1554|        scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: true }
  1555|      });
  1556|      gsap.to('.hero-wm', {
  1557|        y: 80,
  1558|        ease: 'none',
  1559|        scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: true }
  1560|      });
  1561|    }
  1562|
  1563|    /* Off-canvas menu toggle */
  1564|    const navToggle = document.getElementById('navToggle');
  1565|    const offcanvasMenu = document.getElementById('offcanvasMenu');
  1566|    const offcanvasOverlay = document.getElementById('offcanvasOverlay');
  1567|    const offcanvasClose = document.getElementById('offcanvasClose');
  1568|
  1569|    function openOffcanvas() {
  1570|      offcanvasMenu.classList.add('active');
  1571|      offcanvasOverlay.classList.add('active');
  1572|      navToggle.classList.add('active');
  1573|      navToggle.setAttribute('aria-expanded', 'true');
  1574|      offcanvasMenu.setAttribute('aria-hidden', 'false');
  1575|      document.body.style.overflow = 'hidden';
  1576|    }
  1577|    function closeOffcanvas() {
  1578|      offcanvasMenu.classList.remove('active');
  1579|      offcanvasOverlay.classList.remove('active');
  1580|      navToggle.classList.remove('active');
  1581|      navToggle.setAttribute('aria-expanded', 'false');
  1582|      offcanvasMenu.setAttribute('aria-hidden', 'true');
  1583|      document.body.style.overflow = '';
  1584|    }
  1585|
  1586|    if (navToggle && offcanvasMenu) {
  1587|      navToggle.addEventListener('click', () => {
  1588|        const isOpen = offcanvasMenu.classList.contains('active');
  1589|        isOpen ? closeOffcanvas() : openOffcanvas();
  1590|      });
  1591|      offcanvasClose.addEventListener('click', closeOffcanvas);
  1592|      offcanvasOverlay.addEventListener('click', closeOffcanvas);
  1593|      offcanvasMenu.querySelectorAll('a').forEach(link => {
  1594|        link.addEventListener('click', closeOffcanvas);
  1595|      });
  1596|      document.addEventListener('keydown', (e) => {
  1597|        if (e.key === 'Escape' && offcanvasMenu.classList.contains('active')) closeOffcanvas();
  1598|      });
  1599|    }
  1600|
  1601|  })();
  1602|  </script>
  1603|</body>
  1604|</html>
