              </div>
            </div>

            <form class="contacto-form" id="contactForm" onsubmit="return enviarWhatsApp(event)">
              <label for="cf-nombre">Nombre</label>
              <input type="text" id="cf-nombre" name="nombre" placeholder="Tu nombre" required>

              <label for="cf-telefono">Teléfono</label>
              <input type="tel" id="cf-telefono" name="telefono" placeholder="Tu número de teléfono" required>

              <label for="cf-mensaje">Mensaje</label>
              <textarea id="cf-mensaje" name="mensaje" placeholder="¿En qué podemos ayudarte?" required></textarea>

              <button type="submit" class="btn btn-red">Enviar por WhatsApp</button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
